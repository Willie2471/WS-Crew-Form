      servicePerformed: fState.service==='other' ? document.getElementById('f-oth-service')?.value : '',
    };

    await fetch(WEBHOOK_JOB, { method:'POST', body: new URLSearchParams(payload), mode:'no-cors' });

    if (fState.pet==='warn' || payload.notes) {
      await fetch(WEBHOOK_ALERT, { method:'POST', body: new URLSearchParams({
        type:'office_alert', customerName: c.name, serviceAddress: c.address, date,
        petAlert: fState.pet==='warn' ? '⚠️ PET WASTE REPORTED' : '',
        officeNote: payload.notes, toEmail:'info@wslawncareservicesllc.com',
      }), mode:'no-cors' });
    }

    await fetch(WEBHOOK_SHEET, { method:'POST', body: new URLSearchParams({
      type:'sheet_update', customerName: c.name, serviceAddress: c.address,
      email: c.email, grassType: grassVal, mowingHeight: heightVal,
      mowingDirection: payload.mowingDirection, lastVisitDuration: dur,
      lastVisitTechs: techVal, startTime: payload.startTime, endTime: payload.endTime, date,
    }), mode:'no-cors' });

    // Mark dispatch job complete
    if (appState.selectedJobIdx !== null) {
      appState.dispatchJobs[appState.selectedJobIdx].jobStatus = 'complete';
      renderDispatch();
      updateDispatchStrip();
      appState.selectedJobIdx = null;
    }

    document.getElementById('form-body').classList.add('hidden');
    document.getElementById('form-success').classList.add('show');

  } catch(err) {
    if (err.name==='TypeError') {
      document.getElementById('form-body').classList.add('hidden');
      document.getElementById('form-success').classList.add('show');
    } else {
      showToast('❌ Submission failed');
      btn.disabled=false; btn.innerHTML='✓ SUBMIT JOB';
    }
  }
}

function fReset() {
  fState = { customer:null, service:null, grass:'', dir:'', pet:'', techs:[], startTime:null, endTime:null, photos:[] };
  document.getElementById('form-body').classList.remove('hidden');
  document.getElementById('form-success').classList.remove('show');
  fClearCustomer();
  ['res','com','oth'].forEach(t => {
    document.getElementById('f-svc-'+t).classList.remove('active');
    document.getElementById('f-fields-'+t).classList.add('hidden');
  });
  document.getElementById('f-fields-all').classList.add('hidden');
  document.getElementById('f-checklist').classList.add('hidden');
  document.getElementById('f-no-svc-msg').classList.remove('hidden');
  document.getElementById('f-photo-previews').innerHTML = '';
  document.getElementById('f-notes').value = '';
  document.querySelectorAll('.yn-btn.active').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.yn-group.invalid').forEach(b => b.classList.remove('invalid'));
  document.getElementById('f-pet-clear').classList.remove('active-clean');
  document.getElementById('f-pet-warn').classList.remove('active-warn');
  // reset time
  ['f-start-block','f-end-block'].forEach(id => document.getElementById(id).classList.remove('recorded'));
  document.getElementById('f-start-disp').textContent='Not set'; document.getElementById('f-start-disp').classList.add('empty');
  document.getElementById('f-end-disp').textContent='Not set';   document.getElementById('f-end-disp').classList.add('empty');
  document.getElementById('f-start-btn').textContent='TAP TO START'; document.getElementById('f-start-btn').classList.remove('recorded'); document.getElementById('f-start-btn').disabled=false;
  document.getElementById('f-end-btn').textContent='TAP TO END'; document.getElementById('f-end-btn').classList.remove('recorded'); document.getElementById('f-end-btn').disabled=true;
  document.getElementById('f-dur-row').classList.remove('show');
  document.querySelectorAll('.tech-btn').forEach(b => b.classList.remove('selected'));
  document.getElementById('f-tech-val').value='';
  document.getElementById('f-submit-btn').disabled=false;
  document.getElementById('f-submit-btn').innerHTML='✓ SUBMIT JOB';
  window.scrollTo(0,0);
}

// tech rendering for form
function renderFormTechs(techs) {
  const container = document.getElementById('f-tech-select');
  container.innerHTML = techs.map((t,i) => {
    const init = t.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    return `<div class="tech-btn" id="ftb-${i}" onclick="fToggleTech(${i},'${t.name}')">
      <div class="tech-avatar">${init}</div>
      <span class="tech-name">${t.name}</span>
    </div>`;
  }).join('');
}
let fSelectedTechs = [];
function fToggleTech(idx, name) {
  const btn = document.getElementById('ftb-'+idx);
  const ai  = fSelectedTechs.indexOf(name);
  if (ai>-1) { fSelectedTechs.splice(ai,1); btn.classList.remove('selected'); }
  else        { fSelectedTechs.push(name);   btn.classList.add('selected'); }
  document.getElementById('f-tech-val').value = fSelectedTechs.join(', ');
}

// ══════════════════════════════════════
// CUSTOMER LOOKUP
// ══════════════════════════════════════
function doLookup(q) {
  const res = document.getElementById('lookup-results');
  if (q.length < 2) { res.innerHTML = '<div style="text-align:center;padding:32px;color:var(--muted);font-size:14px">Start typing to search customers</div>'; return; }
  const matches = appState.customers.filter(c =>
    c.name.toLowerCase().includes(q.toLowerCase()) || c.address.toLowerCase().includes(q.toLowerCase())
  );
  if (!matches.length) { res.innerHTML = '<div style="text-align:center;padding:32px;color:var(--muted);font-size:14px">No customers found</div>'; return; }
  res.innerHTML = matches.map(c => {
    const chips = [c.grassType, c.mowingHeight ? c.mowingHeight+'"' : '', c.mowingDirection].filter(Boolean);
    return `<div class="customer-card" onclick="openCustomerDetail(${appState.customers.indexOf(c)})">
      <div class="cc-name">${c.name}</div>
      <div class="cc-addr">📍 ${c.address}</div>
      ${chips.length ? `<div class="cc-chips">${chips.map(ch=>`<span class="cc-chip">${ch}</span>`).join('')}</div>` : ''}
    </div>`;
  }).join('');
}

function openCustomerDetail(idx) {
  appState.selectedCustomerIdx = idx;
  const c = appState.customers[idx];
  const rows = [
    ['Name', c.name], ['Address', c.address], ['Email', c.email], ['Phone', c.phone],
    ['Grass Type', c.grassType], ['Last Height', c.mowingHeight ? c.mowingHeight+'"' : ''],
    ['Mow Direction', c.mowingDirection], ['Last Visit', c.lastVisitDuration ? c.lastVisitDuration+' hrs' : ''],
    ['Note', c.internalNote],
  ].filter(r => r[1]);
  document.getElementById('customer-detail-content').innerHTML = `
    <div class="modal-title">${c.name}</div>
    <div class="modal-sub" style="margin-bottom:10px">${c.address}</div>
    ${rows.map(r=>`<div class="detail-row"><span class="detail-label">${r[0]}</span><span class="detail-val">${r[1]}</span></div>`).join('')}`;
  document.getElementById('customer-detail-modal').classList.add('open');
}
function closeCustomerDetail() { document.getElementById('customer-detail-modal').classList.remove('open'); }
function startJobForCustomer() {
  closeCustomerDetail();
  fSelectCustomer(appState.selectedCustomerIdx);
  switchTab('form');
}

// ══════════════════════════════════════
// OFFICE BOARD
// ══════════════════════════════════════
function renderBoard() {
  const posts = appState.boardPosts;
  const boardEl   = document.getElementById('board-posts');
  const homeBoard = document.getElementById('home-board-msgs');

  if (!posts.length) {
    boardEl.innerHTML = '<div class="board-empty-state"><div class="be-icon">📋</div><div class="be-text">No messages from the office yet.</div></div>';
    homeBoard.innerHTML = '<div class="board-empty">No messages from office</div>';
    return;
  }
  const postHtml = posts.map(p => `
    <div class="board-post ${p.tag}">
      <span class="bp-tag ${p.tag}">${p.tag.toUpperCase()}</span>
      <div class="bp-text">${p.text}</div>
      <div class="bp-meta">📅 ${p.time}</div>
    </div>`).join('');
  boardEl.innerHTML = postHtml;

  const preview = posts.slice(0,2).map(p => `<div class="board-msg"><div class="bm-text">${p.text}</div><div class="bm-meta">${p.time}</div></div>`).join('');
  homeBoard.innerHTML = preview;
}

// ══════════════════════════════════════
// NAV
// ══════════════════════════════════════
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  document.getElementById('nav-'+tab).classList.add('active');
  document.getElementById('app-content').scrollTo(0,0);
  if (tab === 'form') updateFormShortcuts();
}

// ══════════════════════════════════════
// UTILS
// ══════════════════════════════════════
function fmtTime(d) {
  return d.toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit', hour12:true });
}
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
// close modals on overlay tap
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});
