function quickJobAction(idx) {
  const job = appState.dispatchJobs[idx];
  if (job.jobStatus === 'complete') return;
  if (job.jobStatus === 'dispatched') {
    appState.dispatchJobs[idx].jobStatus = 'in-progress';
    prefillFormFromJob(idx);
    switchTab('form');
  } else if (job.jobStatus === 'in-progress') {
    prefillFormFromJob(idx);
    switchTab('form');
  }
  renderDispatch();
}

