function prefillFormFromJob(idx) {
  const job = appState.dispatchJobs[idx];
  // Find matching customer
  const match = appState.customers.find(c =>
    c.name.toLowerCase().includes(job.client.toLowerCase().split(',')[0].trim().toLowerCase()) ||
    job.client.toLowerCase().includes(c.name.toLowerCase().split(' ').pop().toLowerCase())
  );
  if (match) {
    fSelectCustomer(appState.customers.indexOf(match));
  } else {
    // Create a synthetic customer from dispatch data
    fState.customer = { name: job.client, address: '', email: '', phone: '', mowingHeight: '', grassType: '', mowingDirection: '', internalNote: '', lastVisitDuration: '' };
    document.getElementById('f-search-section').classList.add('hidden');
    document.getElementById('f-customer-selected').classList.remove('hidden');
    document.getElementById('f-sel-name').textContent = job.client;
    document.getElementById('f-sel-details').innerHTML = job.service ? '🔧 ' + job.service : '';
  }
  // map service type
  const svcLower = (job.service || '').toLowerCase();
  if (svcLower.includes('commercial')) fSelectService('commercial');
  else if (svcLower.includes('mow')) fSelectService('residential');
  // Mark in-progress
  appState.dispatchJobs[idx].jobStatus = 'in-progress';
  renderDispatch();
  updateDispatchStrip();
  document.getElementById('app-content').scrollTo(0,0);
}

