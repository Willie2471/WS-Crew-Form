      perimeter:   document.getElementById('f-perim').value,
      blowLot:     fState.service==='commercial' ? document.getElementById('f-blow').value : '',
      notes:       document.getElementById('f-notes').value,
      petStatus:   fState.pet,
      startTime:   fState.startTime?.display || '',
      endTime:     fState.endTime?.display || '',
      jobDuration: dur,
      photoCount: photoUrls.length,
      photo1Url: photoUrls[0]||'', photo2Url: photoUrls[1]||'',
      photo3Url: photoUrls[2]||'', photo4Url: photoUrls[3]||'',
      photosHtml: photoUrls.length
