    const dur      = fState.startTime && fState.endTime ? ((fState.endTime.ts - fState.startTime.ts)/3600000).toFixed(2) : '';

    const payload = {
      type:'job_complete', date, submittedAt: new Date().toISOString(),
      customerName: c.name, customerEmail: c.email, customerPhone: c.phone,
      serviceAddress: c.address, serviceType: fState.service,
