async function fSubmit() {
  if (!fState.customer) { showToast('⚠ Please select a customer'); return; }
  if (!fState.service)  { showToast('⚠ Please select a service type'); return; }

  const checkIds = ['f-weed','f-bugs','f-hedges','f-perim'];
  if (fState.service === 'commercial') checkIds.unshift('f-blow');
  let fail = false;
  checkIds.forEach(id => {
    const v = document.getElementById(id)?.value;
    const g = document.getElementById('yn-'+id);
    if (!v) { fail=true; if(g) g.classList.add('invalid'); }
    else     { if(g) g.classList.remove('invalid'); }
  });
  if (fail) {
    showToast('⚠ Complete all checklist items');
    document.querySelector('.yn-group.invalid')?.scrollIntoView({behavior:'smooth',block:'center'});
    return;
  }

  const btn = document.getElementById('f-submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Submitting...';

  try {
    const c   = fState.customer;
    const date= new Date().toLocaleDateString('en-US');
    const photos = fState.photos.filter(Boolean);
    const photoData = await Promise.all(photos.map(compressPhoto));
    const photoUrls = [];

    for (let i=0;i<photoData.length;i++) {
      btn.innerHTML = `<span class="spinner"></span> Photo ${i+1}/${photoData.length}...`;
      try {
        const r = await fetch(CLOUDFLARE_WORKER, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ photo: photoData[i].data, filename:`${c.name} - ${date} - ${i+1}.jpg` }) });
        const j = await r.json();
        if (j.url) photoUrls.push(j.url);
