function openDispatchModal() {
  document.getElementById('dispatch-modal').classList.add('open');
}
function closeDispatchModal() {
  document.getElementById('dispatch-modal').classList.remove('open');
}

function parseAndLoadDispatch() {
  const raw = document.getElementById('dispatch-paste-area').value.trim();
  if (!raw) { showToast('⚠ Nothing to parse'); return; }

  const lines = raw.split('\n').map(l => l.trim()).filter(l => l.length > 0);
  const jobs = [];

  for (const line of lines) {
    // Skip header lines
    if (/job date|client name|appointment|job status|job type|service|source/i.test(line)) continue;
    if (/^\$/.test(line) && line.split(/\s+/).length <= 2) continue; // total row

    // Split on 2+ spaces or tabs to get columns
    const cols = line.split(/\t|\s{2,}/).map(c => c.trim()).filter(c => c);
    if (cols.length < 3) continue;

    // Try to extract date (MM/DD/YY format)
    const dateMatch = cols[0]?.match(/\d{1,2}\/\d{1,2}\/\d{2,4}/);
    const jobDate = dateMatch ? cols[0] : '';

    // Build job from columns based on position
    // Col: 0=date, 1=client, 2=start_time, 3=end_time, 4=amount, 5=status, 6=job_type, 7=service, 8=source
    let idx = dateMatch ? 0 : -1;
    const client   = cols[idx+1] || cols[0] || '';
    const startT   = cols[idx+2] || '';
    const endT     = cols[idx+3] || '';
    const amount   = cols[idx+4] || '';
    const status   = cols[idx+5] || 'Dispatched';
    const jobType  = cols[idx+6] || '';
    const service  = cols[idx+7] || cols[idx+6] || '';
    const source   = cols[idx+8] || '';

    // Only add if we got a client name that looks real
    if (!client || client.length < 2) continue;
    if (/^\$/.test(client)) continue;

    jobs.push({
      date: jobDate || new Date().toLocaleDateString('en-US'),
      client: client.replace(/,\s*/g, ', '),
      startTime: normalizeTime(startT),
      endTime:   normalizeTime(endT),
      amount,
      status,
      jobType,
      service,
      source,
      jobStatus: 'dispatched', // app-level status
    });
  }

  if (!jobs.length) {
    showToast('⚠ No jobs found — check format');
    return;
  }

  appState.dispatchJobs = jobs;
  closeDispatchModal();
  document.getElementById('dispatch-paste-area').value = '';
  renderDispatch();
  updateDispatchStrip();
  showToast('✅ ' + jobs.length + ' jobs loaded');
}

function normalizeTime(t) {
  if (!t) return '';
  // already has AM/PM
  if (/[AP]M/i.test(t)) return t;
  // try HH:MM → leave as is
  return t;
}

function renderDispatch() {
  const list = document.getElementById('dispatch-list');
  const jobs = appState.dispatchJobs;
  if (!jobs.length) {
    list.innerHTML = `<div class="dispatch-empty"><div class="de-icon">📋</div><div class="de-title">No jobs loaded yet</div><p>Tap "Load Today's Jobs" to paste the dispatch report</p></div>`;
    return;
  }

  // Group by start time
  const groups = {};
  jobs.forEach((j,i) => {
    const key = j.startTime || 'Unscheduled';
    if (!groups[key]) groups[key] = [];
    groups[key].push({ job: j, idx: i });
  });

  let html = '';
  for (const [time, items] of Object.entries(groups)) {
    html += `<div class="time-group-header">${time}</div>`;
    for (const { job, idx } of items) {
      const statusClass = job.jobStatus === 'complete' ? 'complete' : job.jobStatus === 'in-progress' ? 'in-progress' : 'dispatched';
      const statusLabel = job.jobStatus === 'complete' ? 'Complete' : job.jobStatus === 'in-progress' ? 'In Progress' : 'Dispatched';
      const btnLabel = job.jobStatus === 'complete' ? '✓ Done' : job.jobStatus === 'in-progress' ? 'Complete Job →' : 'Start →';
      const btnClass = job.jobStatus === 'complete' ? 'done-label' : job.jobStatus === 'in-progress' ? 'complete-job' : 'begin';
      html += `
        <div class="job-card ${job.jobStatus === 'complete' ? 'done' : ''}" onclick="openJobDetail(${idx})">
          <div class="job-card-top">
            <div class="job-card-left">
              <div class="job-client">${job.client}</div>
              <div class="job-service">${job.service || job.jobType}</div>
              <div class="job-time-row">🕐 <span>${job.startTime}</span> – <span>${job.endTime}</span></div>
            </div>
            <div class="job-amount-badge">${job.amount}</div>
          </div>
          <div class="job-status-bar">
            <span class="job-status-pill ${statusClass}">${statusLabel}</span>
            <button class="job-start-btn ${btnClass}" onclick="event.stopPropagation();quickJobAction(${idx})">${btnLabel}</button>
          </div>
        </div>`;
    }
  }
  list.innerHTML = html;
  updateDispatchBadge();
  updateFormShortcuts();
}

function updateDispatchStrip() {
  const total    = appState.dispatchJobs.length;
  const done     = appState.dispatchJobs.filter(j => j.jobStatus === 'complete').length;
  const remaining = total - done;
  document.getElementById('strip-jobs-count').textContent = total || '—';
  document.getElementById('strip-jobs-sub').textContent = total ? `${done} done · ${remaining} remaining` : 'Tap to view dispatch';
}

function updateDispatchBadge() {
  const remaining = appState.dispatchJobs.filter(j => j.jobStatus !== 'complete').length;
  const badge = document.getElementById('dispatch-badge');
  const navItem = document.getElementById('nav-dispatch');
  if (remaining > 0) {
    badge.textContent = remaining;
    navItem.classList.add('has-badge');
