<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>WS Crew — Field App</title>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="WS Crew"/>
<meta name="theme-color" content="#0f2a14"/>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --g900: #0f2a14;
  --g800: #1a3d20;
  --g700: #1e6b2e;
  --g600: #2e8b42;
  --g400: #4caf63;
  --g200: #c8e6cc;
  --g100: #e8f5eb;
  --g50:  #f0f7f1;
  --acc:  #f4a100;
  --acc2: #fff3cd;
  --red:  #c0392b;
  --red-pale: #fdf0ee;
  --blue: #1565c0;
  --blue-pale: #e3f2fd;
  --blue-mid: #90caf9;
  --white: #ffffff;
  --text: #1c2b1f;
  --muted: #5a7060;
  --border: #c2d9c6;
  --card-shadow: 0 2px 12px rgba(30,107,46,0.08);
  --radius: 14px;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

html, body {
  height: 100%;
  font-family: 'Barlow', sans-serif;
  background: var(--g50);
  color: var(--text);
  overflow-x: hidden;
}

/* ── SCREENS ── */
.screen { display: none; min-height: 100vh; }
.screen.active { display: flex; flex-direction: column; }

/* ══════════════════════════════════════
   LOGIN SCREEN
══════════════════════════════════════ */
#screen-login {
  background: linear-gradient(160deg, var(--g900) 0%, var(--g800) 50%, #0a2010 100%);
  align-items: center;
  justify-content: center;
  padding: 24px;
  position: relative;
  overflow: hidden;
}
#screen-login::before {
  content: '';
  position: absolute;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46,139,66,0.15) 0%, transparent 70%);
  top: -200px; right: -200px;
  pointer-events: none;
}
#screen-login::after {
  content: '';
  position: absolute;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(244,161,0,0.08) 0%, transparent 70%);
  bottom: -150px; left: -100px;
  pointer-events: none;
}

.login-box {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(20px);
  border-radius: 24px;
  padding: 40px 32px;
  width: 100%;
  max-width: 380px;
  text-align: center;
  position: relative;
  z-index: 1;
}
.login-logo {
  width: 72px; height: 72px;
  background: var(--g700);
  border: 2px solid var(--g600);
  border-radius: 20px;
  display: flex; align-items: center; justify-content: center;
  font-size: 36px;
  margin: 0 auto 20px;
  box-shadow: 0 8px 32px rgba(30,107,46,0.4);
}
.login-brand {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  margin-bottom: 6px;
}
.login-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 30px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1px;
  margin-bottom: 4px;
}
.login-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  margin-bottom: 32px;
}

/* Name selector */
.name-select-wrap {
  margin-bottom: 16px;
  text-align: left;
}
.name-select-wrap label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(255,255,255,0.4);
  display: block;
  margin-bottom: 6px;
}
.name-select-wrap select {
  width: 100%;
  padding: 14px 16px;
  background: rgba(255,255,255,0.08);
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  color: #fff;
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  font-weight: 500;
  outline: none;
  -webkit-appearance: none;
  cursor: pointer;
}
.name-select-wrap select option { background: var(--g900); color: #fff; }
.name-select-wrap select:focus { border-color: var(--g400); }

/* PIN pad */
.pin-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(255,255,255,0.4);
  text-align: left;
  margin-bottom: 8px;
}
.pin-dots {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 20px;
}
.pin-dot {
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.25);
  background: transparent;
  transition: all 0.2s;
}
.pin-dot.filled {
  background: var(--g400);
  border-color: var(--g400);
  box-shadow: 0 0 8px rgba(76,175,99,0.6);
}
.pin-dot.error {
  background: var(--red);
  border-color: var(--red);
  animation: shake 0.3s;
}
@keyframes shake {
  0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)}
}

.pin-pad {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 16px;
}
.pin-key {
  aspect-ratio: 1;
  max-height: 64px;
  background: rgba(255,255,255,0.07);
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 24px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  display: flex; align-items: center; justify-content: center;
}
.pin-key:active { background: rgba(76,175,99,0.3); border-color: var(--g400); transform: scale(0.94); }
.pin-key.del { font-size: 18px; }
.pin-key.enter {
  background: var(--g700);
  border-color: var(--g600);
  grid-column: span 3;
  max-height: 52px;
  font-size: 16px;
  letter-spacing: 2px;
}
.pin-key.enter:active { background: var(--g600); }

.login-error {
  font-size: 13px;
  color: #ff6b6b;
  font-weight: 600;
  min-height: 18px;
  text-align: center;
}

/* ══════════════════════════════════════
   MAIN APP SHELL
══════════════════════════════════════ */
#screen-app {
  background: var(--g50);
  flex-direction: column;
}

/* Top bar */
.topbar {
  background: var(--g900);
  padding: 12px 16px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 16px rgba(0,0,0,0.3);
}
.topbar-left { display: flex; align-items: center; gap: 10px; }
.topbar-icon {
  width: 34px; height: 34px;
  background: var(--g700);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}
.topbar-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5px;
  line-height: 1;
}
.topbar-role {
  font-size: 11px;
  color: rgba(255,255,255,0.45);
  margin-top: 1px;
}
.topbar-right { display: flex; align-items: center; gap: 8px; }
.clock-badge {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  padding: 5px 10px;
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  font-family: 'Barlow Condensed', sans-serif;
  letter-spacing: 0.5px;
}
.clock-badge.clocked-in {
  background: rgba(76,175,99,0.2);
  border-color: var(--g400);
  color: var(--g400);
}
.logout-btn {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  cursor: pointer;
  font-family: 'Barlow', sans-serif;
}
.logout-btn:active { background: rgba(192,57,43,0.3); color: #ff6b6b; }

/* Scroll content */
.app-content {
  flex: 1;
  overflow-y: auto;
  padding: 16px 14px 100px;
  max-width: 680px;
  width: 100%;
  margin: 0 auto;
}

/* Bottom nav */
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--g900);
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  padding: 8px 0 env(safe-area-inset-bottom, 8px);
  z-index: 100;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 6px 0;
  cursor: pointer;
  transition: all 0.2s;
}
.nav-item .nav-icon { font-size: 22px; line-height: 1; }
.nav-item .nav-label {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: rgba(255,255,255,0.35);
  transition: color 0.2s;
}
.nav-item.active .nav-label { color: var(--g400); }
.nav-item .nav-badge {
  position: absolute;
  top: 4px;
  background: var(--acc);
  color: var(--g900);
  font-size: 10px;
  font-weight: 700;
  border-radius: 100px;
  padding: 1px 5px;
  display: none;
}
.nav-item.has-badge .nav-badge { display: block; }
.nav-item:active { opacity: 0.7; }

/* Tab panels */
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* ── SHARED CARD ── */
.card {
  background: var(--white);
  border-radius: var(--radius);
  padding: 18px;
  margin-bottom: 14px;
  border: 1.5px solid var(--border);
  box-shadow: var(--card-shadow);
}
.card-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--g700);
  letter-spacing: 0.3px;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.card-title .ctnum {
  background: var(--g700);
  color: #fff;
  width: 26px; height: 26px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px;
  flex-shrink: 0;
}
.section-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--muted);
  margin-bottom: 8px;
}

/* ══════════════════════════════════════
   TAB: HOME / CLOCK
══════════════════════════════════════ */
.day-hero {
  background: linear-gradient(135deg, var(--g900) 0%, var(--g800) 100%);
  border-radius: var(--radius);
  padding: 22px 20px;
  margin-bottom: 14px;
  position: relative;
  overflow: hidden;
}
.day-hero::after {
  content: '🌿';
  position: absolute;
  right: 16px; bottom: -10px;
  font-size: 80px;
  opacity: 0.08;
  transform: rotate(-15deg);
}
.day-hero-date {
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.45);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 6px;
}
.day-hero-greeting {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: #fff;
  line-height: 1.1;
  margin-bottom: 16px;
}
.day-hero-greeting span { color: var(--g400); }

/* Clock in/out button */
.clock-btn-wrap { margin-bottom: 14px; }
.clock-btn {
  width: 100%;
  padding: 18px;
  border-radius: 14px;
  border: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 1.5px;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
.clock-btn.start {
  background: linear-gradient(135deg, var(--g700), var(--g600));
  color: #fff;
  box-shadow: 0 6px 24px rgba(30,107,46,0.35);
}
.clock-btn.stop {
  background: linear-gradient(135deg, #b71c1c, var(--red));
  color: #fff;
  box-shadow: 0 6px 24px rgba(192,57,43,0.35);
}
.clock-btn:active { transform: scale(0.98); }
.clock-btn .btn-sub {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0;
  opacity: 0.75;
  display: block;
  margin-top: 2px;
}

.time-status-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin-bottom: 14px;
}
.time-stat {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 12px;
  padding: 12px 10px;
  text-align: center;
}
.time-stat .ts-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--muted);
  margin-bottom: 4px;
}
.time-stat .ts-val {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--g700);
  line-height: 1;
}
.time-stat .ts-val.empty { font-size: 14px; color: var(--g200); }
.time-stat.live { border-color: var(--g400); background: var(--g100); }
.time-stat.live .ts-val { color: var(--g700); }

/* Today's job count strip */
.jobs-strip {
  background: var(--acc2);
  border: 1.5px solid var(--acc);
  border-radius: 12px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
  cursor: pointer;
  transition: all 0.15s;
}
.jobs-strip:active { transform: scale(0.99); }
.jobs-strip .js-left { display: flex; align-items: center; gap: 10px; }
.jobs-strip .js-icon { font-size: 24px; }
.jobs-strip .js-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--g900);
}
.jobs-strip .js-sub { font-size: 12px; color: var(--muted); }
.jobs-strip .js-count {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 36px;
  font-weight: 800;
  color: var(--g700);
  line-height: 1;
}

/* Office board preview */
.board-preview {
  background: var(--white);
  border-radius: var(--radius);
  padding: 14px 16px;
  margin-bottom: 14px;
  border: 1.5px solid var(--border);
}
.board-preview-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--muted);
  margin-bottom: 8px;
}
.board-msg {
  background: var(--g100);
  border-left: 3px solid var(--g700);
  border-radius: 0 8px 8px 0;
  padding: 10px 12px;
  margin-bottom: 8px;
}
.board-msg:last-child { margin-bottom: 0; }
.board-msg .bm-text { font-size: 14px; color: var(--text); line-height: 1.5; }
.board-msg .bm-meta { font-size: 11px; color: var(--muted); margin-top: 4px; }
.board-empty { font-size: 13px; color: var(--muted); font-style: italic; text-align: center; padding: 16px; }

/* ══════════════════════════════════════
   TAB: DISPATCH
══════════════════════════════════════ */
.dispatch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.dispatch-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--g900);
}
.dispatch-date-badge {
  background: var(--g100);
  border: 1px solid var(--g200);
  border-radius: 100px;
  padding: 4px 12px;
  font-size: 12px;
  font-weight: 600;
  color: var(--g700);
}
.refresh-btn {
  background: var(--g700);
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 9px 16px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
  transition: all 0.2s;
}
.refresh-btn:active { background: var(--g600); transform: scale(0.97); }
.refresh-btn.loading { opacity: 0.7; }

/* Time group headers */
.time-group-header {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 8px 4px 6px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.time-group-header::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* Job card */
.job-card {
  background: var(--white);
  border-radius: 12px;
  border: 1.5px solid var(--border);
  margin-bottom: 10px;
  overflow: hidden;
  transition: all 0.2s;
  cursor: pointer;
}
.job-card:active { transform: scale(0.99); }
.job-card.done { opacity: 0.6; }
.job-card-top {
  padding: 14px 14px 10px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}
.job-card-left { flex: 1; }
.job-client {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 19px;
  font-weight: 700;
  color: var(--g900);
  line-height: 1.1;
  margin-bottom: 3px;
}
.job-service {
  font-size: 13px;
  font-weight: 600;
  color: var(--g700);
  margin-bottom: 4px;
}
.job-time-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--muted);
}
.job-time-row span { font-weight: 600; }
.job-amount-badge {
  background: var(--g100);
  border: 1px solid var(--g200);
  border-radius: 8px;
  padding: 4px 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--g700);
  white-space: nowrap;
  flex-shrink: 0;
}
.job-status-bar {
  border-top: 1px solid var(--g100);
  padding: 8px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.job-status-pill {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 3px 10px;
  border-radius: 100px;
}
.job-status-pill.dispatched { background: var(--blue-pale); color: var(--blue); }
.job-status-pill.in-progress { background: var(--acc2); color: #b37800; }
.job-status-pill.complete { background: var(--g100); color: var(--g700); }
.job-start-btn {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.5px;
  padding: 6px 14px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.job-start-btn.begin { background: var(--g700); color: #fff; }
.job-start-btn.complete-job { background: var(--g400); color: var(--g900); }
.job-start-btn.done-label {
  background: transparent;
  color: var(--muted);
  font-size: 12px;
  cursor: default;
}
.job-start-btn:active:not(.done-label) { transform: scale(0.96); opacity: 0.85; }

/* dispatch empty */
.dispatch-empty {
  text-align: center;
  padding: 48px 20px;
  color: var(--muted);
}
.dispatch-empty .de-icon { font-size: 48px; margin-bottom: 12px; }
.dispatch-empty .de-title { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; color: var(--g900); margin-bottom: 6px; }
.dispatch-empty p { font-size: 14px; }

/* Paste dispatch modal */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 500;
  align-items: flex-end;
  justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-sheet {
  background: var(--white);
  border-radius: 20px 20px 0 0;
  padding: 24px 20px 40px;
  width: 100%;
  max-width: 680px;
  max-height: 85vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.modal-handle {
  width: 40px; height: 4px;
  background: var(--border);
  border-radius: 2px;
  margin: 0 auto 20px;
}
.modal-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--g900);
  margin-bottom: 6px;
}
.modal-sub { font-size: 13px; color: var(--muted); margin-bottom: 16px; }
.modal-textarea {
  width: 100%;
  min-height: 200px;
  padding: 12px 14px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  font-family: 'Barlow', sans-serif;
  font-size: 13px;
  color: var(--text);
  resize: vertical;
  outline: none;
  margin-bottom: 12px;
}
.modal-textarea:focus { border-color: var(--g700); }
.modal-actions { display: flex; gap: 10px; }
.modal-btn {
  flex: 1;
  padding: 14px;
  border-radius: 12px;
  border: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 0.5px;
  cursor: pointer;
  transition: all 0.2s;
}
.modal-btn.primary { background: var(--g700); color: #fff; }
.modal-btn.secondary { background: var(--g100); color: var(--g700); }
.modal-btn:active { transform: scale(0.98); }

/* Job detail sheet */
.job-detail-info { margin-bottom: 16px; }
.job-detail-row {
  display: flex;
  gap: 8px;
  padding: 9px 0;
  border-bottom: 1px solid var(--g100);
  font-size: 14px;
}
.job-detail-row:last-child { border-bottom: none; }
.job-detail-row .jdr-label { font-weight: 600; color: var(--muted); min-width: 110px; flex-shrink: 0; font-size: 13px; }
.job-detail-row .jdr-val { color: var(--text); font-weight: 500; }

/* ══════════════════════════════════════
   TAB: JOB FORM
══════════════════════════════════════ */
/* (reuses styles from main form — field, yn-group, etc.) */
.form-shortcut-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
  overflow-x: auto;
  padding-bottom: 4px;
}
.form-shortcut-bar::-webkit-scrollbar { display: none; }
.shortcut-pill {
  flex-shrink: 0;
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 100px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 600;
  color: var(--muted);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.15s;
}
.shortcut-pill.active { background: var(--g700); border-color: var(--g700); color: #fff; }
.shortcut-pill:active { transform: scale(0.97); }

/* form fields */
.field { margin-bottom: 14px; }
.field label {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}
.field input, .field select, .field textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  color: var(--text);
  background: #f9fcf9;
  outline: none;
  transition: border-color 0.2s;
  -webkit-appearance: none;
}
.field input:focus, .field select:focus, .field textarea:focus {
  border-color: var(--g700);
  background: #fff;
}
.field textarea { min-height: 80px; resize: vertical; }

.yn-group { display: flex; gap: 8px; }
.yn-btn {
  flex: 1;
  padding: 10px 6px;
  border: 2px solid var(--border);
  border-radius: 10px;
  text-align: center;
  cursor: pointer;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  background: #f9fcf9;
  transition: all 0.2s;
  user-select: none;
}
.yn-btn.yes.active { border-color: var(--g700); background: var(--g100); color: var(--g700); }
.yn-btn.no.active { border-color: var(--red); background: var(--red-pale); color: var(--red); }
.yn-btn.next.active { border-color: var(--acc); background: var(--acc2); color: #b37800; }
.yn-group.invalid .yn-btn { border-color: var(--red) !important; background: var(--red-pale) !important; }

.grass-grid, .dir-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 8px;
}
.grass-btn, .dir-btn {
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 6px;
  text-align: center;
  cursor: pointer;
  background: #f9fcf9;
  transition: all 0.2s;
}
.grass-btn .gicon, .dir-btn .dicon { font-size: 20px; display: block; margin-bottom: 4px; }
.grass-btn .glabel, .dir-btn .dlabel { font-size: 11px; font-weight: 700; color: var(--muted); line-height: 1.3; }
.grass-btn.active, .dir-btn.active { border-color: var(--g700); background: var(--g100); }
.grass-btn.active .glabel, .dir-btn.active .dlabel { color: var(--g700); }

.service-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 4px; }
.service-btn { border: 2px solid var(--border); border-radius: 12px; padding: 14px 8px; text-align: center; cursor: pointer; transition: all 0.2s; background: #f9fcf9; }
.service-btn .sicon { font-size: 26px; display: block; margin-bottom: 5px; }
.service-btn .slabel { font-size: 11px; font-weight: 700; color: var(--muted); line-height: 1.3; }
.service-btn.active { border-color: var(--g700); background: var(--g100); }
.service-btn.active .slabel { color: var(--g700); }

.tech-select { display: flex; flex-wrap: wrap; gap: 8px; padding: 4px 0; }
.tech-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 14px;
  border: 2px solid var(--border);
  border-radius: 100px;
  background: #f9fcf9;
  cursor: pointer;
  transition: all 0.2s;
}
.tech-btn .tech-avatar {
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--g200); color: var(--g700);
  font-size: 10px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.tech-btn .tech-name { font-size: 13px; font-weight: 600; color: var(--muted); }
.tech-btn.selected { border-color: var(--g700); background: var(--g100); }
.tech-btn.selected .tech-avatar { background: var(--g700); color: #fff; }
.tech-btn.selected .tech-name { color: var(--g700); }

.divider { height: 1px; background: var(--g200); margin: 14px 0; }

.customer-selected-banner {
  background: var(--g100);
  border: 1.5px solid var(--g200);
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 14px;
}
.customer-selected-banner .csb-name { font-weight: 700; font-size: 16px; color: var(--g700); }
.customer-selected-banner .csb-details { font-size: 13px; color: var(--muted); margin-top: 3px; line-height: 1.5; }
.customer-selected-banner .csb-change { font-size: 13px; color: var(--g700); font-weight: 600; cursor: pointer; text-decoration: underline; background: none; border: none; padding: 0; margin-top: 6px; }

.info-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
.info-chip {
  display: flex; align-items: center; gap: 5px;
  background: var(--g100); border: 1px solid var(--g200);
  border-radius: 8px; padding: 5px 10px;
}
.info-chip .chip-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); }
.info-chip .chip-value { font-size: 13px; font-weight: 700; color: var(--g700); }
.info-chip.time-chip { background: var(--blue-pale); border-color: var(--blue-mid); }
.info-chip.time-chip .chip-label, .info-chip.time-chip .chip-value { color: var(--blue); }

/* search */
.search-wrap { position: relative; }
.search-wrap input { padding-left: 40px; }
.search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 16px; pointer-events: none; }
.search-results {
  position: absolute; top: calc(100% + 4px); left: 0; right: 0;
  background: #fff; border: 1.5px solid var(--g700); border-radius: 10px;
  max-height: 200px; overflow-y: auto; z-index: 200;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12); display: none;
}
.search-results.open { display: block; }
.search-result-item { padding: 10px 12px; cursor: pointer; border-bottom: 1px solid var(--g100); }
.search-result-item:last-child { border-bottom: none; }
.search-result-item:hover { background: var(--g100); }
.search-result-item .sri-name { font-weight: 700; font-size: 14px; }
.search-result-item .sri-addr { font-size: 12px; color: var(--muted); margin-top: 2px; }

.photo-upload-area {
  border: 2.5px dashed var(--g200); border-radius: 12px;
  padding: 22px 16px; text-align: center; cursor: pointer;
  background: #f9fcf9; position: relative; transition: all 0.2s;
}
.photo-upload-area:hover { border-color: var(--g700); background: var(--g100); }
.photo-upload-area input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.photo-previews { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-top: 10px; }
.photo-thumb { position: relative; aspect-ratio: 1; border-radius: 8px; overflow: hidden; border: 1.5px solid var(--border); }
.photo-thumb img { width: 100%; height: 100%; object-fit: cover; }
.photo-thumb .remove-photo { position: absolute; top: 3px; right: 3px; background: rgba(0,0,0,0.55); color: #fff; border: none; border-radius: 50%; width: 20px; height: 20px; font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center; }

.submit-btn {
  width: 100%; padding: 16px;
  background: var(--g700); color: #fff; border: none;
  border-radius: 12px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px; letter-spacing: 1px;
  cursor: pointer; transition: all 0.2s;
  box-shadow: 0 4px 16px rgba(30,107,46,0.3);
  margin-top: 6px;
}
.submit-btn:disabled { background: var(--muted); cursor: not-allowed; box-shadow: none; }
.submit-btn:active:not(:disabled) { transform: scale(0.99); }

.form-success {
  text-align: center; padding: 40px 20px; display: none;
}
.form-success.show { display: block; }
.form-success .fs-icon { font-size: 64px; margin-bottom: 12px; animation: pop 0.4s ease; }
@keyframes pop { 0%{transform:scale(0.5);opacity:0} 80%{transform:scale(1.1)} 100%{transform:scale(1);opacity:1} }
.form-success h2 { font-family: 'Barlow Condensed', sans-serif; font-size: 26px; color: var(--g700); margin-bottom: 6px; }
.form-success p { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
.form-success .new-job-btn { padding: 12px 28px; background: var(--g700); color: #fff; border: none; border-radius: 10px; font-family: 'Barlow Condensed', sans-serif; font-size: 16px; cursor: pointer; }

.alert-card-wrap { background: #fef5ec; border: 1.5px solid var(--acc); border-radius: var(--radius); padding: 18px; margin-bottom: 14px; }
.alert-card-wrap .card-title { color: var(--acc); }

.pet-toggle { display: flex; gap: 10px; }
.pet-option { flex: 1; border: 2px solid var(--border); border-radius: 12px; padding: 12px 8px; text-align: center; cursor: pointer; background: #f9fcf9; transition: all 0.2s; }
.pet-option .picon { font-size: 24px; display: block; margin-bottom: 5px; }
.pet-option .plabel { font-size: 11px; font-weight: 700; color: var(--muted); line-height: 1.3; }
.pet-option.active-clean { border-color: var(--g700); background: var(--g100); }
.pet-option.active-warn { border-color: var(--red); background: var(--red-pale); }

/* Time tracker */
.time-tracker-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
.time-block { border: 2px solid var(--blue-mid); border-radius: 12px; padding: 12px 10px; text-align: center; background: #fff; }
.time-block.recorded { border-color: var(--blue); background: var(--blue-pale); }
.time-block .tb-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--blue); margin-bottom: 6px; }
.time-block .tb-time { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 700; color: var(--blue); min-height: 28px; line-height: 1; margin-bottom: 8px; }
.time-block .tb-time.empty { font-size: 13px; color: var(--blue-mid); font-family: 'Barlow', sans-serif; font-weight: 500; }
.time-tap-btn { width: 100%; padding: 8px 6px; background: var(--blue); color: #fff; border: none; border-radius: 8px; font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; }
.time-tap-btn.recorded { background: #388e3c; }
.time-tap-btn:disabled { background: #aaa; }
.duration-row { display: none; background: #fff; border: 2px solid var(--blue); border-radius: 10px; padding: 10px 14px; margin-bottom: 14px; align-items: center; gap: 8px; justify-content: center; }
.duration-row.show { display: flex; }
.duration-row .dur-val { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 700; color: var(--blue); }

/* spinner */
.spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.35); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; margin-right: 6px; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ══════════════════════════════════════
   TAB: CUSTOMER LOOKUP
══════════════════════════════════════ */
.lookup-search-wrap { position: relative; margin-bottom: 16px; }
.lookup-search-wrap input { padding: 14px 14px 14px 44px; border-radius: 12px; border: 1.5px solid var(--border); font-size: 15px; background: var(--white); }
.lookup-search-wrap input:focus { border-color: var(--g700); }
.lookup-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 18px; }

.customer-card {
  background: var(--white);
  border-radius: 12px;
  border: 1.5px solid var(--border);
  padding: 14px 16px;
  margin-bottom: 10px;
  cursor: pointer;
  transition: all 0.15s;
}
.customer-card:active { transform: scale(0.99); background: var(--g100); }
.customer-card .cc-name { font-family: 'Barlow Condensed', sans-serif; font-size: 19px; font-weight: 700; color: var(--g900); margin-bottom: 3px; }
.customer-card .cc-addr { font-size: 13px; color: var(--muted); margin-bottom: 6px; }
.customer-card .cc-chips { display: flex; flex-wrap: wrap; gap: 6px; }
.customer-card .cc-chip { background: var(--g100); border: 1px solid var(--g200); border-radius: 6px; padding: 3px 8px; font-size: 11px; font-weight: 600; color: var(--g700); }

/* customer detail sheet */
.detail-row { display: flex; gap: 8px; padding: 10px 0; border-bottom: 1px solid var(--g100); }
.detail-row:last-child { border-bottom: none; }
.detail-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); min-width: 120px; }
.detail-val { font-size: 14px; color: var(--text); font-weight: 500; }

.action-btn-row { display: flex; gap: 8px; margin-top: 14px; }
.action-btn {
  flex: 1; padding: 12px 8px;
  border-radius: 10px; border: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 15px; font-weight: 700; letter-spacing: 0.3px;
  cursor: pointer; transition: all 0.2s;
}
.action-btn.primary { background: var(--g700); color: #fff; }
.action-btn.secondary { background: var(--g100); color: var(--g700); border: 1.5px solid var(--g200); }
.action-btn:active { transform: scale(0.97); }

/* ══════════════════════════════════════
   TAB: BOARD
══════════════════════════════════════ */
.board-post {
  background: var(--white);
  border-radius: 12px;
  border-left: 4px solid var(--g700);
  padding: 14px 16px;
  margin-bottom: 10px;
  box-shadow: var(--card-shadow);
}
.board-post.urgent { border-left-color: var(--red); }
.board-post.info { border-left-color: var(--blue); }
.board-post .bp-tag {
  font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
  padding: 2px 8px; border-radius: 4px; margin-bottom: 6px; display: inline-block;
}
.board-post .bp-tag.general { background: var(--g100); color: var(--g700); }
.board-post .bp-tag.urgent { background: var(--red-pale); color: var(--red); }
.board-post .bp-tag.info { background: var(--blue-pale); color: var(--blue); }
.board-post .bp-text { font-size: 15px; color: var(--text); line-height: 1.6; margin-bottom: 8px; }
.board-post .bp-meta { font-size: 11px; color: var(--muted); }
.board-empty-state { text-align: center; padding: 48px 20px; }
.board-empty-state .be-icon { font-size: 48px; margin-bottom: 12px; }
.board-empty-state .be-text { font-size: 14px; color: var(--muted); }

/* Toast */
.toast {
  position: fixed; bottom: 80px; left: 50%;
  transform: translateX(-50%) translateY(60px);
  background: var(--g900); color: #fff;
  padding: 10px 22px; border-radius: 100px;
  font-size: 14px; font-weight: 500;
  transition: transform 0.3s; z-index: 9999;
  white-space: nowrap; pointer-events: none;
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* Loading state */
.loading-state { display: flex; align-items: center; gap: 10px; padding: 16px; color: var(--muted); font-size: 14px; }
.dot-pulse { display: flex; gap: 4px; }
.dot-pulse span { width: 6px; height: 6px; background: var(--g700); border-radius: 50%; animation: dp 1.2s infinite ease-in-out; }
.dot-pulse span:nth-child(2) { animation-delay: 0.2s; }
.dot-pulse span:nth-child(3) { animation-delay: 0.4s; }
@keyframes dp { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }

.hidden { display: none !important; }
</style>
</head>
<body>

<!-- ══════════════════════════════════════
     LOGIN SCREEN
══════════════════════════════════════ -->
<div class="screen active" id="screen-login">
  <div class="login-box">
    <div class="login-logo">🌿</div>
    <div class="login-brand">WS Lawn Care Services</div>
    <div class="login-title">CREW APP</div>
    <div class="login-sub">Brevard County Field Operations</div>

    <div class="name-select-wrap">
      <label>Select Your Name</label>
      <select id="login-name-select">
        <option value="">Loading crew...</option>
      </select>
    </div>

    <div class="pin-label">Enter Your PIN</div>
    <div class="pin-dots" id="pin-dots">
      <div class="pin-dot" id="pd0"></div>
      <div class="pin-dot" id="pd1"></div>
      <div class="pin-dot" id="pd2"></div>
      <div class="pin-dot" id="pd3"></div>
    </div>

    <div class="pin-pad">
      <div class="pin-key" onclick="pinKey('1')">1</div>
      <div class="pin-key" onclick="pinKey('2')">2</div>
      <div class="pin-key" onclick="pinKey('3')">3</div>
      <div class="pin-key" onclick="pinKey('4')">4</div>
      <div class="pin-key" onclick="pinKey('5')">5</div>
      <div class="pin-key" onclick="pinKey('6')">6</div>
      <div class="pin-key" onclick="pinKey('7')">7</div>
      <div class="pin-key" onclick="pinKey('8')">8</div>
      <div class="pin-key" onclick="pinKey('9')">9</div>
      <div class="pin-key del" onclick="pinDel()">⌫</div>
      <div class="pin-key" onclick="pinKey('0')">0</div>
      <div class="pin-key enter" onclick="pinSubmit()">ENTER</div>
    </div>
    <div class="login-error" id="login-error"></div>
  </div>
</div>

<!-- ══════════════════════════════════════
     MAIN APP
══════════════════════════════════════ -->
<div class="screen" id="screen-app">

  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-icon">🌿</div>
      <div>
        <div class="topbar-name" id="tb-name">—</div>
        <div class="topbar-role" id="tb-role">—</div>
      </div>
    </div>
    <div class="topbar-right">
      <div class="clock-badge" id="tb-clock-badge">NOT IN</div>
      <div class="logout-btn" onclick="doLogout()">OUT</div>
    </div>
  </div>

  <!-- Scrollable content -->
  <div class="app-content" id="app-content">

    <!-- ── HOME TAB ── -->
    <div class="tab-panel active" id="tab-home">
      <div class="day-hero">
        <div class="day-hero-date" id="home-date"></div>
        <div class="day-hero-greeting">Good morning,<br><span id="home-name">—</span> 👋</div>
      </div>

      <!-- Clock in/out -->
      <div class="clock-btn-wrap">
        <button class="clock-btn start" id="main-clock-btn" onclick="toggleClockInOut()">
          <span>🟢 START YOUR DAY</span>
        </button>
      </div>

      <div class="time-status-row">
        <div class="time-stat" id="stat-in">
          <div class="ts-label">Clocked In</div>
          <div class="ts-val empty" id="stat-in-val">—</div>
        </div>
        <div class="time-stat live" id="stat-dur">
          <div class="ts-label">On Clock</div>
          <div class="ts-val" id="stat-dur-val">—</div>
        </div>
        <div class="time-stat" id="stat-out">
          <div class="ts-label">Clocked Out</div>
          <div class="ts-val empty" id="stat-out-val">—</div>
        </div>
      </div>

      <!-- Jobs strip -->
      <div class="jobs-strip" onclick="switchTab('dispatch')">
        <div class="js-left">
          <span class="js-icon">📋</span>
          <div>
            <div class="js-title">Today's Jobs</div>
            <div class="js-sub" id="strip-jobs-sub">Tap to view dispatch</div>
          </div>
        </div>
        <div class="js-count" id="strip-jobs-count">—</div>
      </div>

      <!-- Office board preview -->
      <div class="board-preview">
        <div class="board-preview-label">📌 Office Board</div>
        <div id="home-board-msgs">
          <div class="board-empty">No messages from office</div>
        </div>
      </div>
    </div>

    <!-- ── DISPATCH TAB ── -->
    <div class="tab-panel" id="tab-dispatch">
      <div class="dispatch-header">
        <div>
          <div class="dispatch-title">Daily Dispatch</div>
          <div class="dispatch-date-badge" id="dispatch-date-badge"></div>
        </div>
      </div>
      <button class="refresh-btn" onclick="openDispatchModal()">
        📥 Load Today's Jobs
      </button>
      <div id="dispatch-list">
        <div class="dispatch-empty">
          <div class="de-icon">📋</div>
          <div class="de-title">No jobs loaded yet</div>
          <p>Tap "Load Today's Jobs" to paste the dispatch report</p>
        </div>
