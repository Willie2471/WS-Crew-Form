<script>
// ══════════════════════════════════════
// CONFIG
// ══════════════════════════════════════
const APPS_SCRIPT_URL    = 'https://script.google.com/macros/s/AKfycbxuGa7IjVnaZdYrzECByJX3cVyShnNceMfmKOYN36-3iHa0xKKVUdLqcLXlYmn37W_s/exec';
const WEBHOOK_JOB        = 'https://hooks.zapier.com/hooks/catch/20549459/ux4fnqk/';
const WEBHOOK_ALERT      = 'https://hooks.zapier.com/hooks/catch/20549459/uxw6ope/';
const WEBHOOK_SHEET      = 'https://hooks.zapier.com/hooks/catch/20549459/uxwh463/';
const WEBHOOK_CLOCKIN    = 'https://hooks.zapier.com/hooks/catch/20549459/uxwh463/'; // reuse or set new
const CLOUDFLARE_WORKER  = 'https://wsphotoupload.will-671.workers.dev/';

// ══════════════════════════════════════
// APP STATE
// ══════════════════════════════════════
let appState = {
  crew: [],        // { name, position, pin }
  customers: [],
  currentUser: null,  // { name, position }
  clockInTime: null,
  clockOutTime: null,
  clockedIn: false,
  dispatchJobs: [],
  boardPosts: [],
  selectedJobIdx: null,
  selectedCustomerIdx: null,
};

// form state
let fState = {
  customer: null,
  service: null,
  grass: '',
  dir: '',
  pet: '',
  techs: [],
  startTime: null,
  endTime: null,
  photos: [],
};

// ══════════════════════════════════════
// INIT — load sheet data
// ══════════════════════════════════════
async function init() {
  // Demo board posts
  appState.boardPosts = [
    { tag: 'general', text: 'Great work this week team! Remember to log all job times.', time: 'Today 8:00 AM' },
    { tag: 'info',    text: 'Reminder: double-check gate codes before each visit. If changed, update in office note.', time: 'Yesterday 5:00 PM' },
  ];

  try {
    const res  = await fetch(APPS_SCRIPT_URL + '?token=wslawn-data-2026');
    const data = await res.json();
    if (data.customers?.length) appState.customers = data.customers;
    if (data.techs?.length) {
      appState.crew = data.techs; // pins come from sheet col C
      populateLoginDropdown(data.techs);
      renderFormTechs(data.techs);
    }
  } catch(e) {
    console.warn('Sheet load failed, using defaults');
    const defaults = [
      { name: 'Willie Arreola',  position: 'Crew Lead',   pin: '1234' },
      { name: 'William Arreola', position: 'Field Tech',  pin: '2345' },
      { name: 'Sandra Arreola',  position: 'Field Tech',  pin: '3456' },
    ];
    appState.crew = defaults;
    populateLoginDropdown(defaults);
    renderFormTechs(defaults);
  }

  // Restore session
  try {
    const saved = sessionStorage.getItem('ws_crew_user');
    if (saved) {
      appState.currentUser = JSON.parse(saved);
      const ci = sessionStorage.getItem('ws_clock_in');
      if (ci) { appState.clockInTime = new Date(ci); appState.clockedIn = true; }
      showApp();
    }
  } catch(e) {}
}
init();

function populateLoginDropdown(crew) {
  const sel = document.getElementById('login-name-select');
  sel.innerHTML = '<option value="">— Select your name —</option>' +
    crew.map((c,i) => `<option value="${i}">${c.name}</option>`).join('');
}

// ══════════════════════════════════════
// PIN LOGIN
// ══════════════════════════════════════
let pinBuffer = '';

function pinKey(k) {
  if (pinBuffer.length >= 4) return;
  pinBuffer += k;
  updatePinDots();
  if (pinBuffer.length === 4) setTimeout(pinSubmit, 100);
}
function pinDel() {
  pinBuffer = pinBuffer.slice(0,-1);
  updatePinDots();
}
function updatePinDots() {
  for (let i=0;i<4;i++) {
    document.getElementById('pd'+i).classList.toggle('filled', i < pinBuffer.length);
    document.getElementById('pd'+i).classList.remove('error');
  }
}
function pinSubmit() {
  const nameIdx = parseInt(document.getElementById('login-name-select').value);
  if (isNaN(nameIdx) || nameIdx === '') {
    document.getElementById('login-error').textContent = 'Please select your name first';
    pinBuffer = ''; updatePinDots(); return;
  }
  const crew = appState.crew[nameIdx];
  const pin  = crew.pin || '0000';
  if (pinBuffer === pin) {
    appState.currentUser = { name: crew.name, position: crew.position };
    try { sessionStorage.setItem('ws_crew_user', JSON.stringify(appState.currentUser)); } catch(e){}
    pinBuffer = ''; updatePinDots();
    showApp();
  } else {
    document.getElementById('login-error').textContent = 'Incorrect PIN — try again';
    for (let i=0;i<4;i++) document.getElementById('pd'+i).classList.add('error');
    setTimeout(() => {
      pinBuffer = ''; updatePinDots();
      document.getElementById('login-error').textContent = '';
    }, 1200);
  }
}

function showApp() {
  document.getElementById('screen-login').classList.remove('active');
  document.getElementById('screen-app').classList.add('active');
  const u = appState.currentUser;
  document.getElementById('tb-name').textContent = u.name.split(' ')[0];
  document.getElementById('tb-role').textContent = u.position;
  document.getElementById('home-name').textContent = u.name.split(' ')[0];
  document.getElementById('home-date').textContent = new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  document.getElementById('dispatch-date-badge').textContent = new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
  renderBoard();
  updateClockUI();
  startLiveClock();
}

function doLogout() {
  try { sessionStorage.clear(); } catch(e){}
  document.getElementById('screen-app').classList.remove('active');
  document.getElementById('screen-login').classList.add('active');
  appState.currentUser = null;
  appState.clockedIn = false;
  appState.clockInTime = null;
}

// ══════════════════════════════════════
// CLOCK IN / OUT
// ══════════════════════════════════════
let liveDurInterval = null;

function toggleClockInOut() {
  if (!appState.clockedIn) {
    appState.clockInTime = new Date();
    appState.clockedIn = true;
    try { sessionStorage.setItem('ws_clock_in', appState.clockInTime.toISOString()); } catch(e){}
    sendClockWebhook('Clock In');
    showToast('✅ Day started — ' + fmtTime(appState.clockInTime));
  } else {
    appState.clockOutTime = new Date();
    appState.clockedIn = false;
    try { sessionStorage.removeItem('ws_clock_in'); } catch(e){}
    sendClockWebhook('Clock Out');
    showToast('👋 Day ended — ' + fmtTime(appState.clockOutTime));
    if (liveDurInterval) { clearInterval(liveDurInterval); liveDurInterval = null; }
  }
  updateClockUI();
}

async function sendClockWebhook(type) {
  const payload = new URLSearchParams({
    type: 'clock_event',
    eventType: type,
    techName: appState.currentUser.name,
    position: appState.currentUser.position,
    timestamp: new Date().toISOString(),
    date: new Date().toLocaleDateString('en-US'),
    time: fmtTime(new Date()),
  });
  try {
    await fetch(WEBHOOK_SHEET, { method:'POST', body: payload, mode:'no-cors' });
  } catch(e) {}
}

function updateClockUI() {
  const btn   = document.getElementById('main-clock-btn');
  const badge = document.getElementById('tb-clock-badge');
  const inVal = document.getElementById('stat-in-val');
  const outVal= document.getElementById('stat-out-val');

  if (appState.clockedIn) {
    btn.className = 'clock-btn stop';
    btn.innerHTML = '<span>🔴 END YOUR DAY</span>';
    badge.textContent = 'IN';
    badge.classList.add('clocked-in');
    inVal.textContent = fmtTime(appState.clockInTime);
    inVal.classList.remove('empty');
    outVal.textContent = '—';
    outVal.classList.add('empty');
    startLiveClock();
  } else {
    btn.className = 'clock-btn start';
    btn.innerHTML = '<span>🟢 START YOUR DAY</span>';
    badge.textContent = 'NOT IN';
    badge.classList.remove('clocked-in');
    if (appState.clockOutTime) {
      outVal.textContent = fmtTime(appState.clockOutTime);
      outVal.classList.remove('empty');
    }
  }
}

function startLiveClock() {
  if (liveDurInterval) return;
  liveDurInterval = setInterval(() => {
    if (!appState.clockedIn || !appState.clockInTime) return;
    const diff = (Date.now() - appState.clockInTime) / 3600000;
    document.getElementById('stat-dur-val').textContent = diff.toFixed(2) + 'h';
  }, 10000);
}

